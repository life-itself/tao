#!/bin/sh
# Rebuild portfolio/index.js from markdown frontmatter before each commit.
# If any initiatives/ or projects/ files are staged, regenerate and stage the index.

STAGED=$(git diff --cached --name-only)

if echo "$STAGED" | grep -qE '^(initiatives|projects)/.*\.md$'; then
  echo "Rebuilding portfolio/index.js..."
  node portfolio/scripts/build-index.js || exit 1
  git add portfolio/index.js
fi
